{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/login.html"
    },
    {
      "source": "/index.php/:route*",
      "destination": "/api/index.php?route=:route*"
    },
    {
      "source": "/index.php",
      "destination": "/api/index.php"
    },
    {
      "source": "/image.php",
      "destination": "/api/image.php"
    },
    {
      "source": "/stripe_create_payment_intent.php",
      "destination": "/api/stripe_create_payment_intent.php"
    }
  ]
}
